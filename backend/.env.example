# 1. Kết nối dành cho FastAPI (Async PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname?sslmode=require

# 2. Kết nối dành cho Alembic Migration (Sync PostgreSQL)
ALEMBIC_DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname?sslmode=require

# 3. Secret key cho JWT tokens (CHANGE THIS IN PRODUCTION!)
SECRET_KEY=your-secret-key-change-in-production

# 4. Giữ nguyên các cấu hình khác
GEMINI_API_KEY=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
